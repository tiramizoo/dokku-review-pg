#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PG_VERSION="${REVIEW_PG_VERSION:-18}"

echo "-----> review-pg: Installing PostgreSQL ${PG_VERSION}"

if command -v psql &>/dev/null && psql --version | grep -q "PostgreSQL ${PG_VERSION}"; then
  echo "       PostgreSQL ${PG_VERSION} already installed: $(psql --version)"
else
  # Add official PostgreSQL apt repository
  apt-get install -y -qq curl ca-certificates > /dev/null
  install -d /usr/share/postgresql-common/pgdg
  curl -so /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc --fail \
    https://www.postgresql.org/media/keys/ACCC4CF8.asc

  . /etc/os-release
  echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] https://apt.postgresql.org/pub/repos/apt ${VERSION_CODENAME}-pgdg main" \
    > /etc/apt/sources.list.d/pgdg.list

  apt-get update -qq
  apt-get install -y -qq "postgresql-${PG_VERSION}" > /dev/null
  echo "       Installed: $(psql --version)"
fi

# Ensure a cluster exists for the target version and is running on port 5432
if ! pg_lsclusters -h | grep -q "^${PG_VERSION}.*main"; then
  echo "-----> review-pg: Creating PostgreSQL ${PG_VERSION} cluster"
  pg_createcluster "${PG_VERSION}" main --start --port 5432
fi

systemctl enable --now postgresql

# Detect Docker bridge gateway for container→host connectivity
DOCKER_GW=$(docker network inspect bridge --format '{{range .IPAM.Config}}{{.Gateway}}{{end}}' 2>/dev/null || true)
DOCKER_SUBNET=$(docker network inspect bridge --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}' 2>/dev/null || true)

PG_CONF=$(sudo -u postgres psql -t -c "SHOW config_file;" | xargs)
PG_HBA=$(sudo -u postgres psql -t -c "SHOW hba_file;" | xargs)
PG_CHANGED=false

# Configure password authentication for local TCP connections (used by Dokku apps)
if ! grep -q "host all all 127.0.0.1/32 scram-sha-256" "$PG_HBA"; then
  echo "-----> review-pg: Configuring pg_hba.conf for password auth on localhost"
  sed -i '/^host.*all.*all.*127.0.0.1/d' "$PG_HBA"
  echo "host all all 127.0.0.1/32 scram-sha-256" >> "$PG_HBA"
  PG_CHANGED=true
fi

# Configure PostgreSQL to listen on Docker bridge so containers can connect
if [[ -n "$DOCKER_GW" ]]; then
  echo "-----> review-pg: Configuring PostgreSQL for Docker networking (gateway: ${DOCKER_GW})"

  # Add Docker subnet to pg_hba.conf
  if [[ -n "$DOCKER_SUBNET" ]] && ! grep -q "$DOCKER_SUBNET" "$PG_HBA"; then
    echo "host all all ${DOCKER_SUBNET} scram-sha-256" >> "$PG_HBA"
    PG_CHANGED=true
  fi

  # Add Docker gateway to listen_addresses
  CURRENT_LISTEN=$(sudo -u postgres psql -t -c "SHOW listen_addresses;" | xargs)
  if [[ "$CURRENT_LISTEN" != *"$DOCKER_GW"* ]]; then
    sed -i "s/^[#[:space:]]*listen_addresses = .*/listen_addresses = '${CURRENT_LISTEN},${DOCKER_GW}'/" "$PG_CONF"
    PG_CHANGED=true
  fi

  # Order PostgreSQL after Docker on boot. Without this, systemd parallel-starts
  # both services and Postgres can race past docker0 creation, fail to bind
  # ${DOCKER_GW}, and silently fall back to 127.0.0.1 only — breaking app
  # connectivity until the next manual restart (seen after AWS kernel reboots).
  PG_OVERRIDE_DIR="/etc/systemd/system/postgresql@${PG_VERSION}-main.service.d"
  PG_OVERRIDE_FILE="${PG_OVERRIDE_DIR}/10-docker-ordering.conf"
  PG_OVERRIDE_CONTENT=$'[Unit]\nAfter=docker.service\nRequires=docker.service\n'
  if [[ ! -f "$PG_OVERRIDE_FILE" ]] || [[ "$(cat "$PG_OVERRIDE_FILE")" != "$PG_OVERRIDE_CONTENT" ]]; then
    echo "-----> review-pg: Installing systemd override to start PostgreSQL after Docker"
    install -d "$PG_OVERRIDE_DIR"
    printf '%s' "$PG_OVERRIDE_CONTENT" > "$PG_OVERRIDE_FILE"
    systemctl daemon-reload
  fi
fi

if [[ "$PG_CHANGED" == "true" ]]; then
  systemctl restart postgresql
fi

# Allow dokku user to run psql as postgres without a password
echo "dokku ALL=(postgres) NOPASSWD: /usr/bin/psql" > /etc/sudoers.d/dokku-postgres
chmod 440 /etc/sudoers.d/dokku-postgres

echo "-----> review-pg: PostgreSQL ${PG_VERSION} ready"

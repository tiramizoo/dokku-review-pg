#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$(dirname "$0")/functions"

APP="$1"

fn-review-pg-app-matches "$APP" || exit 0

DATABASES=$(fn-review-pg-get-databases)
DB_USER=$(echo "${APP}" | tr '-' '_')

echo "-----> review-pg: Dropping PostgreSQL resources for ${APP}"

for ENV_VAR in ${DATABASES}; do
  DB_NAME=$(fn-review-pg-db-name "$APP" "$ENV_VAR")
  sudo -u postgres psql -q -c "DROP DATABASE IF EXISTS ${DB_NAME};"
  echo "       Dropped database: ${DB_NAME}"
done

sudo -u postgres psql -q -c "DROP USER IF EXISTS ${DB_USER};"
echo "       Dropped user: ${DB_USER}"
